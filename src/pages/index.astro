---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import TarjetaCurso from "@componentes/TarjetaCurso.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import {
  conRutaBase,
  obtenerConfiguracionSitio,
  obtenerProgramasDestacados
} from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
const programasDestacados = obtenerProgramasDestacados();
---

<DisenoBase rutaActual="/" descripcion={sitio.seo.descripcionBase}>
  <section class="hero">
    <div class="contenedor hero__interior">
      <div class="bloque-titulo hero__contenido">
        <span class="bloque-titulo__etiqueta">{sitio.portada.etiqueta}</span>
        <h1>{sitio.portada.titulo}</h1>
        <p>{sitio.portada.descripcion}</p>
        <div class="botones">
          <BotonWhatsApp
            mensaje={sitio.portada.ctaPrincipal.mensaje}
            etiqueta={sitio.portada.ctaPrincipal.etiqueta}
            evento="clic_whatsapp_portada"
          />
          <a class="boton-secundario" href={conRutaBase(sitio.portada.ctaSecundario.enlace)}>
            {sitio.portada.ctaSecundario.etiqueta}
          </a>
        </div>
      </div>

      <aside class="hero__panel" aria-label="Información principal de Mate Diamante">
        <img src={conRutaBase(sitio.marca.logotipo)} alt={`Logotipo de ${sitio.marca.nombre}`} />
        <div>
          <span>{sitio.marca.eslogan}</span>
          <h2>{sitio.portada.panel.titulo}</h2>
          <p>{sitio.portada.panel.descripcion}</p>
        </div>
        <ul class="lista-limpia lista-compacta">
          {sitio.portada.panel.puntos.map((punto) => (
            <li>{punto}</li>
          ))}
        </ul>
      </aside>
    </div>

    <div class="contenedor hero__metricas">
      {sitio.portada.metricas.map((metrica) => (
        <article>
          <strong>{metrica.valor}</strong>
          <span>{metrica.etiqueta}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="seccion seccion-programas">
    <div class="contenedor">
      <div class="bloque-titulo">
        <span class="bloque-titulo__etiqueta">{sitio.paginas.cursos.etiqueta}</span>
        <h2>{sitio.paginas.cursos.titulo}</h2>
        <p>{sitio.paginas.cursos.descripcion}</p>
      </div>

      <div class="rejilla rejilla-2">
        {programasDestacados.map((programa) => (
          <TarjetaCurso
            programa={programa}
            categoria={sitio.categoriasProgramas.find((categoria) => categoria.id === programa.categoria)}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-dividida">
    <div class="contenedor rejilla rejilla-2">
      <article class="panel-editorial">
        <span class="bloque-titulo__etiqueta">{sitio.metodologia.etiqueta}</span>
        <h2>{sitio.metodologia.titulo}</h2>
        <p>{sitio.metodologia.descripcion}</p>
      </article>

      <div class="lista-pasos">
        {sitio.metodologia.pasos.map((paso, indice) => (
          <article class="paso-metodo">
            <span>{indice + 1}</span>
            <div>
              <h3>{paso.titulo}</h3>
              <p>{paso.descripcion}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-2">
      <article class="llamada llamada-clara">
        <span class="bloque-titulo__etiqueta">{sitio.pruebasConfianza.etiqueta}</span>
        <h2>{sitio.pruebasConfianza.titulo}</h2>
        <p>{sitio.pruebasConfianza.descripcion}</p>
      </article>

      <ul class="lista-limpia lista-pruebas">
        {sitio.pruebasConfianza.elementos.map((elemento) => (
          <li>{elemento}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="seccion seccion-testimonios">
    <div class="contenedor">
      <div class="bloque-titulo">
        <span class="bloque-titulo__etiqueta">{sitio.testimonios.etiqueta}</span>
        <h2>{sitio.testimonios.titulo}</h2>
        <p>{sitio.testimonios.descripcion}</p>
      </div>

      <div class="rejilla rejilla-3">
        {sitio.testimonios.elementos.map((testimonio) => (
          <article class="testimonio">
            {testimonio.imagen && (
              <img
                src={conRutaBase(testimonio.imagen)}
                alt={testimonio.textoAlternativo ?? `Evidencia de ${testimonio.autor}`}
              />
            )}
            <p>“{testimonio.cita}”</p>
            <strong>{testimonio.autor}</strong>
            <span>{testimonio.contexto}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada llamada-final">
        <div>
          <h2>{sitio.llamadas.cierreGeneral.titulo}</h2>
          <p>{sitio.llamadas.cierreGeneral.descripcion}</p>
        </div>
        <BotonWhatsApp
          mensaje={sitio.llamadas.cierreGeneral.cta.mensaje}
          etiqueta={sitio.llamadas.cierreGeneral.cta.etiqueta}
          evento="clic_whatsapp_cierre_inicio"
        />
      </div>
    </div>
  </section>
</DisenoBase>
