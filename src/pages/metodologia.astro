---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
---

<DisenoBase
  titulo="Metodologia"
  descripcion="Conoce como trabaja Mate Diamante para preparar alumnos en linea."
  rutaActual="/metodologia/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">Cómo trabajamos</span>
      <h1>{sitio.metodologia.titulo}</h1>
      <p>{sitio.metodologia.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-2">
      <article class="tarjeta">
        <h2 style="font-family: Space Grotesk, sans-serif; margin-top: 0;">Ruta de acompañamiento</h2>
        <div class="lista-pasos">
          {sitio.metodologia.pasos.map((paso, indice) => (
            <div class="item-con-icono">
              <span>{indice + 1}</span>
              <div>
                <strong>{paso.titulo}</strong>
                <p class="texto-suave" style="margin: 0.2rem 0 0;">{paso.descripcion}</p>
              </div>
            </div>
          ))}
        </div>
      </article>

      <article class="llamada">
        <h2>Operación simple para enfocarse en estudiar</h2>
        <p>
          Nos enfocamos en el material de apoyo, en métodos sencillos y novedosos así como en simplificar tu proceso de inscripción con nosotros. Solicita información a través de nuestro WhatsApp.
        </p>
        <div class="panel-destacado">
          <h3>Nuestro método contempla</h3>
          <ul class="lista-limpia apilado">
            <li>Localizar el objetivo académico del curso que tomarás</li>
            <li>Establecer fechas y horario del grupo accesibles</li>
            <li>Clases en línea con Google Meat para facilitar el acceso</li>
            <li>Canal rápido de soporte e información por WhatsApp</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada">
        <h3>¿Quieres validar qué curso te conviene?</h3>
        <p>
          Una conversación breve por WhatsApp basta para orientarte según la universidad que te interesa, la convocatoria para la que deseas concursar o tu objetivo de concluir la preparatoria.
        </p>
        <BotonWhatsApp
          mensaje="Hola, quiero saber que curso o ruta de preparación me conviene."
          etiqueta="Orientarme por WhatsApp"
          evento="clic_whatsapp_metodologia"
        />
      </div>
    </div>
  </section>
</DisenoBase>
