---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
---

<DisenoBase
  titulo="Contacto"
  descripcion="Canales de contacto de Mate Diamante para informes e inscripciones."
  rutaActual="/contacto/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">Contacto directo</span>
      <h1>El canal principal de atención es nuestro número de WhatsApp Empresarial</h1>
      <p>Contáctanos usando el método oficial y recibe atención personalizada de nuestro equipo
      </p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-2">
      <article class="tarjeta">
        <h2 style="font-family: Space Grotesk, sans-serif; margin-top: 0;">¿Cómo prefieres contactarnos?</h2>
        <div class="lista-contacto">
          <div class="item-con-icono">
            <span>1</span>
            <div>
              <strong>WhatsApp</strong>
              <p class="texto-suave" style="margin: 0.2rem 0 0;">
                El medio principal y más rápido para resolver dudas e iniciar tu proceso de inscripción.
              </p>
            </div>
          </div>
          <div class="item-con-icono">
            <span>2</span>
            <div>
              <strong>Correo</strong>
              <p class="texto-suave" style="margin: 0.2rem 0 0;">{sitio.contacto.correo}</p>
            </div>
          </div>
          <div class="item-con-icono">
            <span>3</span>
            <div>
              <strong>Horario de atención</strong>
              <p class="texto-suave" style="margin: 0.2rem 0 0;">{sitio.contacto.horarioAtencion}</p>
            </div>
          </div>
        </div>
      </article>

      <article class="llamada">
        <h2>Escribe si tienes dudas</h2>
        <p>
          Usa cualquiera de estos botones para iniciar una conversación de acuerdo a tus necesidades. Un tutor o miembro del equipo se pondrá en contacto contigo a la brevedad.
        </p>
        <div class="botones">
          <BotonWhatsApp
            mensaje={sitio.contacto.mensajeGeneralWhatsApp}
            etiqueta="Informes generales"
            evento="clic_whatsapp_contacto_general"
          />
          <BotonWhatsApp
            mensaje="Hola, quiero informes para un curso de ingreso universitario."
            etiqueta="Ingreso universitario"
            clase="boton-secundario"
            evento="clic_whatsapp_contacto_universidad"
          />
          <BotonWhatsApp
            mensaje="Hola, quiero informes para concluir la preparatoria."
            etiqueta="Conclusion de preparatoria"
            clase="boton-secundario"
            evento="clic_whatsapp_contacto_preparatoria"
          />
        </div>
      </article>
    </div>
  </section>
</DisenoBase>
