---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
const pagina = sitio.paginas.contacto;
---

<DisenoBase
  titulo={pagina.tituloSeo}
  descripcion={pagina.descripcionSeo}
  rutaActual="/contacto/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">{pagina.etiqueta}</span>
      <h1>{pagina.titulo}</h1>
      <p>{pagina.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-3">
      {pagina.opciones.map((opcion, indice) => (
        <article class="opcion-contacto">
          <span>{String(indice + 1).padStart(2, "0")}</span>
          <h2>{opcion.titulo}</h2>
          <p>{opcion.descripcion}</p>
          <BotonWhatsApp
            mensaje={opcion.cta.mensaje}
            etiqueta={opcion.cta.etiqueta}
            evento={`clic_whatsapp_contacto_${indice + 1}`}
          />
        </article>
      ))}
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="panel-contacto">
        <div>
          <strong>WhatsApp</strong>
          <a href={`https://wa.me/${sitio.contacto.telefono}`}>{sitio.contacto.telefonoVisible}</a>
        </div>
        <div>
          <strong>Correo</strong>
          <a href={`mailto:${sitio.contacto.correo}`}>{sitio.contacto.correo}</a>
        </div>
        <div>
          <strong>Horario</strong>
          <p>{sitio.contacto.horarioAtencion}</p>
        </div>
      </div>
    </div>
  </section>
</DisenoBase>
