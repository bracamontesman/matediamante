---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
const pagina = sitio.paginas.preguntasFrecuentes;
---

<DisenoBase
  titulo={pagina.tituloSeo}
  descripcion={pagina.descripcionSeo}
  rutaActual="/preguntas-frecuentes/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">{pagina.etiqueta}</span>
      <h1>{pagina.titulo}</h1>
      <p>{pagina.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla">
      {sitio.preguntasFrecuentes.map((item) => (
        <details class="pregunta-frecuente">
          <summary class="pregunta-frecuente__resumen">{item.pregunta}</summary>
          <p class="pregunta-frecuente__respuesta">{item.respuesta}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada llamada-final">
        <div>
          <h2>{sitio.llamadas.cierreGeneral.titulo}</h2>
          <p>{sitio.llamadas.cierreGeneral.descripcion}</p>
        </div>
        <BotonWhatsApp
          mensaje={sitio.llamadas.cierreGeneral.cta.mensaje}
          etiqueta={sitio.llamadas.cierreGeneral.cta.etiqueta}
          evento="clic_whatsapp_preguntas_frecuentes"
        />
      </div>
    </div>
  </section>
</DisenoBase>
