---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
const pagina = sitio.paginas.accesoAlumnos;
---

<DisenoBase
  titulo={pagina.tituloSeo}
  descripcion={pagina.descripcionSeo}
  rutaActual="/acceso-alumnos/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">{pagina.etiqueta}</span>
      <h1>{pagina.titulo}</h1>
      <p>{pagina.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-2">
      <article class="tarjeta-lista">
        <h2>Pasos para entrar a clase</h2>
        <ol class="lista-ordenada">
          {pagina.pasosAcceso.map((paso) => (
            <li>{paso}</li>
          ))}
        </ol>
      </article>

      <article class="tarjeta-lista">
        <h2>Avisos generales</h2>
        <ul class="lista-limpia lista-pruebas">
          {pagina.avisos.map((aviso) => (
            <li>{aviso}</li>
          ))}
        </ul>
        <p class="nota">{pagina.calendarioGeneral}</p>
      </article>
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada llamada-final">
        <div>
          <h2>{pagina.apoyo.titulo}</h2>
          <p>{pagina.apoyo.descripcion}</p>
        </div>
        <BotonWhatsApp
          mensaje={pagina.apoyo.cta.mensaje}
          etiqueta={pagina.apoyo.cta.etiqueta}
          evento="clic_whatsapp_apoyo_alumnos"
        />
      </div>
    </div>
  </section>
</DisenoBase>
