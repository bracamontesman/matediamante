---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import TarjetaCurso from "@componentes/TarjetaCurso.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio, obtenerProgramasVisibles } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
const pagina = sitio.paginas.cursos;
const programas = obtenerProgramasVisibles();
---

<DisenoBase
  titulo={pagina.tituloSeo}
  descripcion={pagina.descripcionSeo}
  rutaActual="/cursos/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">{pagina.etiqueta}</span>
      <h1>{pagina.titulo}</h1>
      <p>{pagina.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="filtros-cursos" data-filtros-cursos>
        <button type="button" aria-pressed="true" data-filtro="todos">Todos</button>
        {sitio.categoriasProgramas.map((categoria) => (
          <button type="button" aria-pressed="false" data-filtro={categoria.id}>
            {categoria.titulo}
          </button>
        ))}
      </div>

      <div class="rejilla rejilla-2" data-lista-cursos>
        {programas.map((programa) => (
          <TarjetaCurso
            programa={programa}
            categoria={sitio.categoriasProgramas.find((categoria) => categoria.id === programa.categoria)}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada llamada-final">
        <div>
          <h2>{sitio.llamadas.cursosNoPublicados.titulo}</h2>
          <p>{sitio.llamadas.cursosNoPublicados.descripcion}</p>
        </div>
        <BotonWhatsApp
          mensaje={sitio.llamadas.cursosNoPublicados.cta.mensaje}
          etiqueta={sitio.llamadas.cursosNoPublicados.cta.etiqueta}
          evento="clic_whatsapp_convocatoria_no_publicada"
        />
      </div>
    </div>
  </section>

  <script is:inline>
    {`
      const grupoFiltros = document.querySelector("[data-filtros-cursos]");
      const tarjetas = Array.from(document.querySelectorAll("[data-lista-cursos] [data-categoria]"));

      grupoFiltros?.addEventListener("click", (evento) => {
        const objetivo = evento.target;
        if (!(objetivo instanceof HTMLButtonElement)) return;

        const filtro = objetivo.dataset.filtro || "todos";

        grupoFiltros.querySelectorAll("button").forEach((boton) => {
          boton.setAttribute("aria-pressed", String(boton === objetivo));
        });

        tarjetas.forEach((tarjeta) => {
          const coincide = filtro === "todos" || tarjeta.dataset.categoria === filtro;
          tarjeta.classList.toggle("curso-oculto", !coincide);
        });
      });
    `}
  </script>
</DisenoBase>
