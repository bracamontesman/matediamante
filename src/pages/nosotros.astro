---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import DisenoBase from "@disenos/DisenoBase.astro";
import { obtenerConfiguracionSitio } from "@utilidades/sitio";

const sitio = obtenerConfiguracionSitio();
---

<DisenoBase
  titulo="Nosotros"
  descripcion="Conoce el enfoque academico y humano de Mate Diamante."
  rutaActual="/nosotros/"
>
  <section class="pagina-encabezado">
    <div class="contenedor bloque-titulo">
      <span class="bloque-titulo__etiqueta">Quiénes somos</span>
      <h1>{sitio.nosotros.titulo}</h1>
      <p>{sitio.nosotros.descripcion}</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor rejilla rejilla-2">
      <article class="tarjeta">
        <h2 style="font-family: Space Grotesk, sans-serif; margin-top: 0;">Estos son los pilares de nuestros cursos:</h2>
        <ul class="lista-limpia lista-pilares">
          {sitio.nosotros.pilares.map((pilar) => (
            <li class="item-con-icono">
              <span>•</span>
              <div>{pilar}</div>
            </li>
          ))}
        </ul>
      </article>

      <article class="llamada">
        <h2>Descubre lo sencillo que es inscribirte a Mate Diamante</h2>
        <p>
          Puedes usar nuestro canal principal de contacto a través de WhatsApp para solicitar información, resolver tus dudas y recibir acompañamiento en tu proceso de inscripción a nuestros cursos.
        </p>
        <div class="panel-destacado">
          <h3>Parte de lo que ofrecemos</h3>
          <ul class="lista-limpia apilado">
            <li>Profesores certificados y experimentados</li>
            <li>Materiales de estudio y apoyo en cada materia</li>
            <li>Programas enfocados en el examen específico de cada universidad</li>
            <li>Metodología revisada y aterrizada para facilitar el aprendizaje</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="seccion-compacta">
    <div class="contenedor">
      <div class="llamada">
        <h3>En Mate Diamante estamos listos para recibir nuevas generaciones</h3>
        <p>
          Si estas evaluando opciones para tu siguiente paso académico, puedes escribirnos y
          contarnos tu caso.
        </p>
        <BotonWhatsApp
          mensaje="Hola, quiero conocer mas sobre Mate Diamante y sus cursos."
          etiqueta="Escribir ahora"
          evento="clic_whatsapp_nosotros"
        />
      </div>
    </div>
  </section>
</DisenoBase>
