---
import { conRutaBase, obtenerConfiguracionSitio } from "@utilidades/sitio";

interface Propiedades {
  rutaActual: string;
}

const { rutaActual } = Astro.props as Propiedades;
const { marca, contacto } = obtenerConfiguracionSitio();

const enlaces = [
  { href: "/", etiqueta: "Inicio" },
  { href: "/cursos/", etiqueta: "Cursos" },
  { href: "/metodologia/", etiqueta: "Metodologia" },
  { href: "/nosotros/", etiqueta: "Nosotros" },
  { href: "/preguntas-frecuentes/", etiqueta: "Preguntas frecuentes" },
  { href: "/contacto/", etiqueta: "Contacto" },
  { href: "/acceso-alumnos/", etiqueta: "Acceso alumnos" }
];
---

<header class="encabezado">
  <div class="contenedor encabezado__interior">
    <a class="encabezado__marca" href={conRutaBase("/")}>
      <img src={conRutaBase(marca.logotipo)} alt={`Logotipo de ${marca.nombre}`} />
      <div>
        <strong>{marca.nombre}</strong>
        <span>{marca.eslogan}</span>
      </div>
    </a>

    <button
      class="encabezado__movil"
      type="button"
      aria-controls="menu-principal"
      aria-expanded="false"
      data-accion-menu
    >
      Menu
    </button>

    <div class="encabezado__menu" id="menu-principal" data-abierto="false">
      <nav class="encabezado__navegacion" aria-label="Principal">
        {enlaces.map((enlace) => (
          <a
            href={conRutaBase(enlace.href)}
            aria-current={rutaActual === enlace.href ? "page" : undefined}
          >
            {enlace.etiqueta}
          </a>
        ))}
      </nav>

      <a
        class="boton-secundario"
        href={`https://wa.me/${contacto.telefono}?text=${encodeURIComponent(
          contacto.mensajeGeneralWhatsApp
        )}`}
        target="_blank"
        rel="noreferrer"
        data-evento="clic_whatsapp_encabezado"
      >
        WhatsApp
      </a>
    </div>
  </div>
</header>
