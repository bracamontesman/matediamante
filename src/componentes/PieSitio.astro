---
import { conRutaBase, obtenerConfiguracionSitio, obtenerEnlaceWhatsApp } from "@utilidades/sitio";

const { marca, contacto, navegacionPrincipal, categoriasProgramas } = obtenerConfiguracionSitio();
---

<footer class="pie">
  <div class="contenedor">
    <div class="pie__rejilla">
      <section class="pie__marca">
        <img src={conRutaBase(marca.logotipo)} alt={`Logotipo de ${marca.nombre}`} />
        <div>
          <strong>{marca.nombre}</strong>
          <p>{marca.descripcionCorta}</p>
        </div>
        {marca.avisoLogotipo && <div class="nota texto-pequeno">{marca.avisoLogotipo}</div>}
      </section>

      <section>
        <h3>Explora</h3>
        <ul>
          {navegacionPrincipal.map((enlace) => (
            <li><a href={conRutaBase(enlace.href)}>{enlace.etiqueta}</a></li>
          ))}
          <li><a href={conRutaBase("/preguntas-frecuentes/")}>Preguntas frecuentes</a></li>
        </ul>
      </section>

      <section>
        <h3>Rutas</h3>
        <ul>
          {categoriasProgramas.map((categoria) => (
            <li><a href={conRutaBase("/cursos/")}>{categoria.titulo}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h3>Contacto</h3>
        <ul>
          <li>
            <a href={obtenerEnlaceWhatsApp(contacto.mensajeGeneralWhatsApp)} target="_blank" rel="noreferrer noopener">
              WhatsApp: {contacto.telefonoVisible}
            </a>
          </li>
          <li><a href={`mailto:${contacto.correo}`}>{contacto.correo}</a></li>
          <li><p>{contacto.horarioAtencion}</p></li>
          <li><p>{contacto.direccionTexto}</p></li>
        </ul>
      </section>
    </div>

    <div class="pie__cierre">
      <p>
        {new Date().getFullYear()} {marca.nombre}. Cursos en línea para aspirantes que quieren avanzar con claridad.
      </p>
    </div>
  </div>
</footer>
