---
import BotonWhatsApp from "@componentes/BotonWhatsApp.astro";
import { obtenerEtiquetaEstado } from "@utilidades/sitio";
import type { CategoriaPrograma, ProgramaAcademico } from "@utilidades/tipos";

interface Propiedades {
  programa: ProgramaAcademico;
  categoria?: CategoriaPrograma;
}

const { programa, categoria } = Astro.props as Propiedades;
---

<article class="tarjeta-programa" data-categoria={programa.categoria} data-estado={programa.estado}>
  <div class="tarjeta-programa__cabecera">
    <span class="insignia-estado" data-estado={programa.estado}>
      {obtenerEtiquetaEstado(programa.estado)}
    </span>
    {categoria && <span class="insignia-ruta">{categoria.titulo}</span>}
  </div>

  <div class="tarjeta-programa__titulo">
    <span>{programa.nombreCorto}</span>
    <h3>{programa.titulo}</h3>
    <p>{programa.descripcion}</p>
  </div>

  <div class="tarjeta-programa__bloque">
    <strong>Ideal para</strong>
    <ul class="lista-limpia lista-compacta">
      {programa.idealPara.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <div class="tarjeta-programa__bloque">
    <strong>Incluye</strong>
    <ul class="lista-limpia lista-compacta">
      {programa.puntosClave.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <BotonWhatsApp
    mensaje={programa.mensajeWhatsApp}
    etiqueta={programa.etiquetaCta}
    evento={`clic_whatsapp_programa_${programa.id}`}
  />
</article>
